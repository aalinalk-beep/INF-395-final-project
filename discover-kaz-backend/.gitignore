# === Python ===
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.pkl
*.log

# Virtual environments
venv/
.venv/
env/
ENV/

# Byte-compiled / optimized / DLL files
*.so
*.dll
*.dylib

# === Django ===
# SQLite database (if used)
db.sqlite3
db.sqlite3-journal

# Django collected static files
/staticfiles/
/static/
static/

# Django local settings
/local_settings.py
*.secret
secret_key.txt

# === Environment variables ===
.env
*.env
*.env.*

# === IDE / Editor garbage ===
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# === OS generated files ===
.DS_Store
Thumbs.db

# === Migrations (optional — usually commit them!) ===
# If you don't want auto-created migration files from local tests:
# */migrations/*/__pycache__/
# */migrations/*.py
# except __init__.py
# !*/migrations/__init__.py

# === Logs ===
logs/
*.log

